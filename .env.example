

# --- DATABASE ---
DB_URL=jdbc:mysql://localhost:3306/agenda_db?serverTmezone=UTC
DB_USERNAME=
DB_PASSWORD=
DB_ROOT_PASSWORD=

# --- JWT ---
# Genera una stringa random di almeno 64 caratteri
# usa openssl rand -base64 64
JWT_SECRET=
JWT_EXPIRATION=36000000

# --- RABBITMQ ---
# In Docker il host è il nome del servizio nel docker-compose
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=
RABBITMQ_PASSWORD=
RABBITMQ_VHOST=/

# --- OAUTH2 GOOGLE ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- MAIL ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# --- APP ---
APP_BASE_URL=http://localhost:4200
DDL_AUTO=update
SHOW_SQL=true